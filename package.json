{
  "name": "aozora-reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "import:aozora": "node scripts/import-aozora.mjs && node scripts/build-learning.mjs",
    "build:learning": "node scripts/build-learning.mjs",
    "translate:grammar": "node scripts/translate-grammar.mjs",
    "db:create": "node scripts/postgres/create-database.mjs",
    "db:migrate": "node scripts/postgres/migrate.mjs",
    "db:import:aozora": "node scripts/postgres/import-all-aozora.mjs",
    "db:import:learning": "node scripts/postgres/import-learning.mjs",
    "db:compact": "node scripts/postgres/compact.mjs",
    "db:verify": "node scripts/postgres/verify.mjs",
    "db:verify:learning": "node scripts/postgres/verify-learning.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:pages": "npm run build && wrangler pages deploy dist/client --project-name aozora-reader --branch main"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "adm-zip": "^0.6.0",
    "csv-parse": "^7.0.1",
    "lucide-react": "^1.25.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@electric-sql/pglite": "^0.5.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/kuromoji": "^0.1.3",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cheerio": "^1.2.0",
    "jsdom": "^29.1.1",
    "kuromoji": "^0.1.2",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=22"
  }
}
